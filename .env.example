# =============================================================================
# EkTola WhatsApp Campaign Platform - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=mysql+pymysql://ektola_user:password@localhost:3306/ektola_db?charset=utf8mb4
# PostgreSQL example: postgresql://user:password@localhost:5432/ektola_db
# SQLite example (for development): sqlite:///./ektola.db

# -----------------------------------------------------------------------------
# Security & JWT Configuration
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Template ID for WhatsApp Messages
# -----------------------------------------------------------------------------
# Note: In production, these should be fetched from Meta directly
WHATSAPP_SIP_REMINDER_TEMPLATE=gold_sip_template
WHATSAPP_LOAN_REMINDER_TEMPLATE=loan_reminder_template

# -----------------------------------------------------------------------------
# Admin Access
# -----------------------------------------------------------------------------
ADMIN_ACCESS_CODE=your-admin-access-code-here

# -----------------------------------------------------------------------------
# Redis Configuration (for Celery task queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Production example: redis://:password@host:port/0

# -----------------------------------------------------------------------------
# WhatsApp Cloud API Configuration
# -----------------------------------------------------------------------------
# Get credentials from: https://developers.facebook.com/apps/

# WhatsApp Embedded Signup (Jeweller Accounts)
WHATSAPP_API_VERSION=v25.0
WHATSAPP_APP_ID=your-facebook-app-id
WHATSAPP_APP_SECRET=your-facebook-app-secret
FACEBOOK_CONFIG_ID=your-facebook-embedded-signup-config-id
FACEBOOK_SDK_URL=https://connect.facebook.net/en_US/sdk.js
FACEBOOK_EMBEDDED_SIGNUP_VERSION=v4
WHATSAPP_TOKEN_ENCRYPTION_KEY=generate-using-fernet-generate-key
WHATSAPP_SYSTEM_USER_TOKEN=your-system-user-access-token

# Platform WhatsApp (for OTPs and admin notifications)
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-business-api-access-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_OTP_TEMPLATE_NAME=otp_verification
WHATSAPP_CALLBACK_BASE_URL=http://localhost:8000

# Setup Instructions:
# 1. Create a Meta App (Business) at https://developers.facebook.com/apps/
# 2. Add WhatsApp product
# 3. Get App ID and App Secret from Settings > Basic
# 4. Create Embedded Signup configuration in WhatsApp > Configuration
# 5. Create System User in Meta Business Manager > Business Settings > Users > System Users
# 6. Generate System User Token with whatsapp_business_management and whatsapp_business_messaging permissions
# 7. Get Phone Number ID from WhatsApp > API Setup
# 8. Generate encryption key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 9. Set up webhook with verify token

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
ENVIRONMENT=development
# Options: development, staging, production
